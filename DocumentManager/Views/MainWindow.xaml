<Window x:Class="DocumentManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Document Manager" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <!-- TabControl with 2 tabs as required -->
    <TabControl>

        <!-- Tab 1: Documents -->
        <TabItem Header="Documents">
            <DockPanel Margin="10">
                <!-- Add button at bottom -->
                <Button DockPanel.Dock="Bottom" Content="Add Document" 
                        Command="{Binding AddDocumentCommand}" 
                        Padding="10,5" Margin="0,10,0,0" HorizontalAlignment="Left"/>

                <!-- Documents list -->
                <ListView ItemsSource="{Binding Documents}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="File Name" Width="120" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Extension" Width="70" DisplayMemberBinding="{Binding Extension}"/>
                            <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding SizeFormatted}"/>
                            <GridViewColumn Header="Full Path" Width="200" DisplayMemberBinding="{Binding FullPath}"/>
                            <GridViewColumn Header="Added At" Width="120" DisplayMemberBinding="{Binding AddedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                            <GridViewColumn Header="Created At" Width="120" DisplayMemberBinding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                            <GridViewColumn Header="Modified At" Width="120" DisplayMemberBinding="{Binding ModifiedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </TabItem>

        <!-- Tab 2: History -->
        <TabItem Header="History">
            <DockPanel Margin="10">
                <!-- Clear History button at bottom -->
                <Button DockPanel.Dock="Bottom" Content="Clear History" 
                        Command="{Binding ClearHistoryCommand}" 
                        Padding="10,5" Margin="0,10,0,0" HorizontalAlignment="Left"/>

                <!-- History list -->
                <ListView ItemsSource="{Binding History}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="File Name" Width="150" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn Header="Action" Width="80" DisplayMemberBinding="{Binding Action}"/>
                            <GridViewColumn Header="Extension" Width="70" DisplayMemberBinding="{Binding Extension}"/>
                            <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding SizeFormatted}"/>
                            <GridViewColumn Header="Date" Width="130" DisplayMemberBinding="{Binding AddedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>

<Window x:Class="DocumentManager.Views.AddDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DocumentManager.Converters"
        Title="Add Document" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <StackPanel Margin="15">
        
        <!-- Browse Button -->
        <Button Content="Browse File..." Command="{Binding BrowseCommand}" 
                Padding="10,5" HorizontalAlignment="Left"/>
        
        <!-- Drag & Drop Area -->
        <Border Margin="0,15" Padding="20" BorderBrush="Gray" BorderThickness="1" 
                Background="LightGray" MinHeight="100">
            <TextBlock Text="Drag and Drop file here" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray"/>
        </Border>
        
        <!-- File Info (shows when file is selected) -->
        <GroupBox Header="File Information" Visibility="{Binding IsFileSelected, Converter={StaticResource BoolToVis}}">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="Bold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FileName}" TextWrapping="Wrap"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" FontWeight="Bold"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FileType}"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Size:" FontWeight="Bold"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileSize}"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Path:" FontWeight="Bold"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FilePath}" TextWrapping="Wrap"/>
                
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Created:" FontWeight="Bold"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CreatedAt}"/>
                
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Modified:" FontWeight="Bold"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ModifiedAt}"/>
            </Grid>
        </GroupBox>
        
        <!-- Error Message (shows when there's an error) -->
        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}"/>
        
        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="15,5" Margin="0,0,10,0"/>
            <Button Content="Confirm" Command="{Binding ConfirmCommand}" Padding="15,5" IsEnabled="{Binding IsValidFile}"/>
        </StackPanel>
        
    </StackPanel>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringToVisibilityConverter x:Key="StringToVis"/>
    </Window.Resources>
</Window>
